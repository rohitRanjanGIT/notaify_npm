{
    "name": "notaify",
    "version": "0.1.0",
    "description": "Error capture and AI-powered notification for Node.js backends",
    "keywords": [
        "error",
        "notification",
        "monitoring",
        "express",
        "fastify",
        "nextjs",
        "nestjs",
        "notaify",
        "error-tracking",
        "ai-powered"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/rohitRanjanGIT/notaify_npm"
    },
    "license": "MIT",
    "author": "rohit",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "main": "./dist/cjs/index.js",
    "types": "./dist/types/index.d.ts",
    "directories": {
        "test": "tests"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:esm": "tsc -p tsconfig.esm.json",
        "build:types": "tsc -p tsconfig.types.json",
        "build": "npm run build:cjs && npm run build:esm && npm run build:types",
        "test": "jest --config jest.config.js",
        "lint": "eslint src/**/*.ts",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.0",
        "eslint": "^8.56.0",
        "@typescript-eslint/eslint-plugin": "^6.19.0",
        "@typescript-eslint/parser": "^6.19.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "typescript": "^5.3.3"
    },
    "peerDependencies": {
        "express": ">=4.0.0"
    },
    "peerDependenciesMeta": {
        "express": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "module": "./dist/esm/index.js"
}